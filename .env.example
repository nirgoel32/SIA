# WikiTree — register at https://www.wikitree.com/wiki/Help:Apps
WIKITREE_APP_ID=ImmigrationJourneyDemo

# FamilySearch — register at https://www.familysearch.org/developers/
# Required for FamilySearch person search & ancestry (unauthenticated session).
FAMILYSEARCH_CLIENT_ID=
# OpenRouter — get a key at https://openrouter.ai/keys
# Used by the LLM geocoder fallback in src/services/geocode.ts (free models only).
OPENROUTER_API_KEY=

# Optional overrides (defaults shown)
# FAMILYSEARCH_AUTH_URL=https://ident.familysearch.org/cis-web/oauth2/v3/token
# FAMILYSEARCH_API_BASE=https://api.familysearch.org/platform
